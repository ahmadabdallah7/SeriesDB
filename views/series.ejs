<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SeriesDB</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/result.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,500;1,500&display=swap" rel="stylesheet">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
</head>

<body>

    <!-- Navbar that includes the SeriesDB logo and the Home page button -->
    <section id="bar">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand ms-3 kanit-medium" href="/">SeriesDB</a>
                <button class="navbar-toggler me-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link roboto" href="/">Home</a>
                        </li>
                    </ul>
                </div>
            </div>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        </nav>
    </section>

    <!-- The search box and form. -->
    <section id="main">
        <div class="container search-box d-flex flex-column justify-content-center align-items-center">
            <div class="row">
                <div class="col-12 col-md-12 col-lg-12 mb-5">
                    <div class="search-container position-relative align-items-center">
                        <form class="d-flex align-items-center" action="/search" method="POST">
                            <svg xmlns="" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                class="search-icon feather feather-search">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                            <input class="form-control search-input ps-5" name="selection" type="search"
                                placeholder="Search anything..." aria-label="Search">
                            <button class="btn btn-search ms-2" type="submit">Search</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- The show card that shows the user the result of their search -->
            <div class="serie">
                <div class="poster">
                    <img src="<%= imageURL %>" />
                </div>
                <div class="details">
                    <h2>
                        <%= showName %> <br /><span>Status: <%= status %></span>
                    </h2>
                    <div class="rating">
                        <p class="mb-0 roboto">Rating: <%= rating %>
                        </p>
                    </div>
                    <div class="tags mb-3">
                        <% genres.forEach(genre=> { %>
                            <span class="badge rounded-pill text-bg-danger roboto">
                                <%= genre %>
                            </span>
                            <% }); %>
                    </div>
                    <div class="info summary-box overflow-y-auto scrollable-text">
                        <%- summary %>
                    </div>
                </div>
            </div>

        </div>

    </section>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <script src="../index.js"></script>
</body>

</html>